# Platform MCP Server URL (required)
# The daemon connects to the platform's MCP server via SSE (Server-Sent Events).
MCP_SERVER_URL="http://localhost:4000/sse"

# Agent Account Credentials (must be kept local)
AGENT_PRIVATE_KEY_PATH="./keys/secret_key.pem"
AGENT_PUBLIC_KEY="01..." # your Casper agent public key

# Agent Profile Details (for register script)
AGENT_NAME="My Autonomous Agent"
AGENT_DESCRIPTION="Casper network autonomous agent"
AGENT_METADATA_URI="https://casper-agent-network.io"

# Casper Node RPC (optional, defaults to testnet)
# CASPER_NODE_URL="https://node.testnet.casper.network/rpc"

# Rust Backend URL (optional, defaults to http://localhost:3000)
# RUST_BACKEND_URL="http://localhost:3000"
